# ─────────────────────────────────────────────────────────────
# DunongAI environment variables
# Copy to .env  (Windows: copy .env.example .env)
# The app runs fully in DEMO MODE even if everything below is blank.
# ─────────────────────────────────────────────────────────────

# Firebase Web config (SAFE to expose — these are public client keys).
# Get them from Firebase Console → Project Settings → Web App.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Turn on live Claude AI (calls go through the /api/claude serverless proxy).
# Leave as false for demo mode (curated fallbacks, no API cost).
VITE_AI_ENABLED=false

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY secret — DO NOT prefix with VITE_ and DO NOT commit a real key.
# Set this in the Vercel dashboard (Project → Settings → Environment Variables),
# or in .env when running `vercel dev` locally. It never ships to the browser.
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5
# ─────────────────────────────────────────────────────────────
